{
  "name": "playscript-js",
  "version": "0.1.0",
  "description": "A TypeScript library for parsing and rendering Japanese Fountain (JFTN) screenplay format",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "dev": "tsc --watch",
    "lint": "eslint src/**/*.ts tests/**/*.ts examples/**/*.ts",
    "lint:fix": "eslint src/**/*.ts tests/**/*.ts examples/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts tests/**/*.ts examples/**/*.ts",
    "example:jftn": "tsx examples/jftn-parsing-demo.ts",
    "example:json": "tsx examples/json-compatibility-demo.ts",
    "example:python": "tsx examples/python-compatibility-demo.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "fountain",
    "screenplay",
    "japanese",
    "jftn",
    "parser",
    "typescript"
  ],
  "author": "satamame <satax@nifty.com>",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.5.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.1.0",
    "tsx": "^4.20.5",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": ""
  }
}
